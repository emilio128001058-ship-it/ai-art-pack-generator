# Copy this file to .env and fill in your values.
# .env is git-ignored so your secrets stay local.

# API key for your image generation service (e.g. Stability AI, Replicate, etc.)
IMAGE_API_KEY=your_image_api_key_here

# Endpoint URL for the image generation API
IMAGE_API_URL=https://your-image-api-endpoint.com/generate

# Zapier "Catch Hook" webhook URL (from your Zapier Zap trigger)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-id/
